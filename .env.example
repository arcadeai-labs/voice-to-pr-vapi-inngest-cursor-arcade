# ---------------------------------------------------------------------------
# voice-to-pr configuration
#
# Copy to `.env` and fill in what you have. Anything you leave blank runs in
# MOCK mode, so you can demo the entire pipeline with zero external accounts.
# Set MOCK_MODE=1 to force every integration to mock even if keys are present.
# ---------------------------------------------------------------------------

# Server
PORT=3000
# Public base URL Vapi should call (e.g. an ngrok/cloudflared tunnel).
# Only used to print setup hints; the webhook path is always /api/vapi.
PUBLIC_URL=

# Force all integrations into mock mode (1 = on). Leave blank for auto-detect.
MOCK_MODE=

# Use the local Inngest dev server (npm run inngest) instead of Inngest Cloud.
# Keep =1 for local dev. For Inngest Cloud, unset this and provide
# INNGEST_EVENT_KEY + INNGEST_SIGNING_KEY instead.
INNGEST_DEV=1

# --- Arcade (per-user authorized tool calls: Linear + Slack) ---------------
# https://docs.arcade.dev/en/get-started/setup/api-keys
ARCADE_API_KEY=
# The end user whose OAuth grants the tools run under (email or stable id).
# This is THE point of Arcade: actions are scoped to a real user, not a bot.
ARCADE_USER_ID=you@example.com

# --- Cursor Cloud Agents (the coding agent that opens the PR) --------------
# https://cursor.com/dashboard -> API Keys  (or a service-account key)
CURSOR_API_KEY=
# Optional explicit model id from GET /v1/models (e.g. composer-2).
# Leave blank to use your Cursor default model.
CURSOR_MODEL=
# Default repo the voice agent works on when the caller doesn't name one.
DEFAULT_REPO_URL=https://github.com/your-org/your-repo

# --- Routing for notifications --------------------------------------------
SLACK_CHANNEL=engineering

# --- Vapi (voice front door) ----------------------------------------------
# Private (server) API key — used by `npm run create-assistant` and to provision
# phone numbers. Public key + assistant id power the /call web button.
VAPI_PRIVATE_KEY=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=
# Optional: verify inbound webhook signatures.
VAPI_SERVER_SECRET=

# --- Mock tuning -----------------------------------------------------------
# How many poll cycles the mock Cursor agent "works" before finishing.
MOCK_AGENT_POLLS=2
